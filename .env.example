# ─────────────────────────────────────────────────────────────
# .env.local — WEIIZ.INK Environment Variables
# ─────────────────────────────────────────────────────────────
# ⚠️  JANGAN commit file ini ke GitHub!
#     Pastikan .env.local ada di .gitignore
# ─────────────────────────────────────────────────────────────

# ── DATABASE ─────────────────────────────────────────────────
# Dapatkan dari: neon.tech (gratis) atau supabase.com
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE"

# ── APP ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Ganti ke: https://weiiz.ink saat production

# ── JWT (Authentication) ──────────────────────────────────────
# Buat string acak minimal 32 karakter
# Generator: https://generate-secret.vercel.app/32
JWT_SECRET="ganti-dengan-string-acak-minimal-32-karakter"
JWT_EXPIRES_IN="7d"

# ── MIDTRANS (Payment Indonesia) ─────────────────────────────
# Daftar di: https://dashboard.midtrans.com
# Sandbox untuk testing, Production untuk live
MIDTRANS_SERVER_KEY="SB-Mid-server-xxxxxxxxxxxxxxxxxxxxxxxx"
MIDTRANS_CLIENT_KEY="SB-Mid-client-xxxxxxxxxxxxxxxxxxxxxxxx"
MIDTRANS_IS_PRODUCTION="false"
# Ganti ke "true" saat live

# ── EMAIL (Resend — gratis 3000 email/bulan) ──────────────────
# Daftar di: https://resend.com
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxx"
EMAIL_FROM="Weiiz.ink <noreply@weiiz.ink>"

# ── GOOGLE OAUTH (Opsional) ───────────────────────────────────
# Buat di: https://console.cloud.google.com
GOOGLE_CLIENT_ID="xxxxxxxx.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-xxxxxxxxxxxxxxxx"

# ── FILE UPLOAD (Uploadthing — gratis 2GB) ────────────────────
# Daftar di: https://uploadthing.com
UPLOADTHING_SECRET="your_uploadthing_secret"
UPLOADTHING_APP_ID="xxxxxxxxxxxxxxxx"
